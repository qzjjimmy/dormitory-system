server.port=8080
spring.application.name=dormitory-system

spring.datasource.url=jdbc:mysql://localhost:3306/dormitory_system?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
spring.datasource.username=root
spring.datasource.password=你的MySQL密码
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.sql.init.mode=never

# 到 https://platform.deepseek.com 申请 API Key
deepseek.api-key=你的DeepSeek-API-Key
deepseek.base-url=https://api.deepseek.com
deepseek.model=deepseek-chat
